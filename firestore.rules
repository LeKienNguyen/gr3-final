rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isManager() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isManager();
      allow update: if isManager() || isOwner(userId);
      allow delete: if isManager();
    }

    match /employees/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isManager();
      allow update: if isManager();
    }

    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isManager();
    }

    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /checklists/{docId} {
      allow read: if isAuthenticated();
      allow create, delete: if isManager();
      allow update: if isAuthenticated();
    }

    match /activities/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /counters/{docId} {
      allow read, write: if isManager();
    }
  }
}
